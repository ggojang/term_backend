  <meta charset="UTF-8">
  <link rel="stylesheet" href="resources/css/map.css">
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>

  <script src="resources/js/map.js"></script>
</head>
<body>
  <div id="title">
    <H3>Mapping Support Tool to SNOMED CT (9 March 2020 Edition including COVID-19 Codes) by InfoClinic</H3>
  </div>
  <fieldset>
    <legend>Semantic Tag (57)</legend>
    <form>
    	<label><input type="radio" name="radioSelect" id="all" value="all" onClick="radioButton('all');" /> All</label>
    	<label><input type="radio" name="radioSelect" id="none" value="none" onClick="radioButton('none');" /> None</label> 
	<label><input type="radio" name="radioSelect" id="diagnosis" value="diagnosis" checked onClick="radioButton('diagnosis');" /> For diagnosis</label>
        <label><input type="radio" name="radioSelect" id="procedure" value="procedure" onClick="radioButton('procedure');" /> For procedure</label>
    </form>

    <script>
      $.each(semanticTags, function(index,item) {
      //for (i=0; i<semanticTags.length; i++) {
        if (index==0 || index==1 || index==4) {
          document.write(
            "<input type=\"checkbox\" name=\"sem_tag\" id=\"sem_tag" + (index+1) + "\""
            + " value=" + item
            + " checked onClick=\"checkBox(\'sem_tag" + (index+1) + "\');\"> " + item
          );
        } else {
          document.write(
            "<input type=\"checkbox\" name=\"sem_tag\" id=\"sem_tag" + (index+1) + "\""
            + " value=" + item
            + " onClick=\"checkBox(\'sem_tag" + (index+1) + "\');\"> " + item
          );
        }
      //}
    })
    </script>
