	<script>
	
	// jqmigrate loggin off
	jQuery.migrateMute = true;
	
	// if access ie, mobile  => redirect infoclinic home 
	redirectForAccessIEOrPhone();

	/**
	 *
	 */
	function redirectForAccessIEOrPhone()
	{
		var isMobile = false;
		var isInternetExplorer = false;

		var userAgent = window.navigator.userAgent.toLowerCase();
		// Iphone, Android Mobile, Ipod, Opera, Window Phone
		isMobile = /mobile|iphone|ipod|mini|iemobile/.test(userAgent);
		// MS Internet Explorer : trident(버전8이상), msie
		// Explorer은 레이아웃 엔진으로 Trident을 사용하지만 버전 8부터 지원하므로 하위 지원을 위해 MSIE를 검사한다.
		isInternetExplorer = /trident|msie/.test(userAgent);

		if (isInternetExplorer)
		{
			alert('Supported Browsers : Chrome 51+, Safari 9.1+, Firefox 46+ \n No Supported Browsers : Internet Explorer and SmartPhones');
			window.open('http://infoclinic.co','_self');
		}
	}

	/**
	 * 아래코드는 keycode.info 처리방법을 참고하였음.
	 * mac chrome또는 firefox에서 delete key 누르면 backspace(페이지 뒤로가기)가 실행되므로 실행되지않도록 하는 메소드
	 * 참고 : http://stackoverflow.com/questions/24764626/any-way-to-prevent-disable-ctrl-key-shortcuts-in-the-browser
	 */
	var body = document.querySelector('body');
	body.onkeydown = function(e) {
		var targetLocalName = e.target.localName;
		if (targetLocalName === 'input') return;

		var keyCode = e.keyCode;
		if (keyCode === 8) {
			e.preventDefault();
			// keyCode table: https://blog.lael.be/post/75
			// metaKey란? http://www.w3schools.com/jsref/event_key_metakey.asp
			// 모든 키보드가 메타키를 가지고있지는 않다.
			// 썬마이크로시스템 키보드, MIT 및 LISP 기계식 키보드는 diamond symbol metakey가 있다.
			// MAC은 Command키가 메타키이다.
			// 메타키와 함께 누르지않은 경우에 대해서는 즉, 키 단독으로 눌렀을때는 다른 이벤트를 예방하도록 한다.
		}
	}
	</script>

