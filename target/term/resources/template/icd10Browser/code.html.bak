
<div id="lb-code">
	<ic-loading loading="eVm.loading" target="#lb-code"></ic-loading>

	<div ng-repeat="ancestors in eVm.ancestors">
		<h3>
			<span ng-if="ancestors.classKind === 'chapter'">Chapter {{ancestors.code}}</span>
			<br>
			<span ng-if="ancestors.classKind === 'chapter'">{{ancestors.label}}</span>
			
		</h3>
		<h4> 
			<span ng-if="ancestors.classKind !=='chapter'">{{ancestors.code}} </span>
			
			<span ng-if="ancestors.classKind !=='chapter'">{{ancestors.label}}</span>
		</h4>

	</div>
  	<hr>

	<!--	
                <p>{{eVm.pcode}}</p>
		<br>
                <p>{{eVm.ancestors}}</p>
                <br>
		<p>{{eVm.siblings}}</p>
		<br>
		<p>{{eVm.rubric}}</p>
	-->
<!--
	<div class="well well-sm" >
		<ul class="breadcrumb" ng-repeat="kinds in eVm.rubrics.kinds">
			<li>{{ kinds.kind }}</li>
			<li class="active">{{ kinds.label }}</li>
		</ul>
	</div>
-->	
	<div ng-if="eVm.pcode.classKind !== 'category'">
		<table border="1">
			<tbody>
				<tr style="font-size:10pt" ng-repeat="(kind1, kind2) in eVm.rubrics.kinds | groupBy:'kind'">
					<td style="width:80px;">
                                		<div ng-switch on="kind1">
                                        		<span ng-switch-when="preferred">Preferred</span>
                                        		<span style="width:50px;font-weight:bold;font-style:italic" ng-switch-when="note">Note</span>
                                        		<span style="width:50px;font-weight:bold;font-style:italic" ng-switch-when="inclusion">Incl.</span>
                                        		<span style="width:50px;font-weight:bold;font-style:italic" ng-switch-when="exclusion">Excl.</span>
                                        		<span style="width:50px;font-weight:bold;font-style:italic" ng-switch-when="introduction">Intro.</span>
                                        		<span ng-switch-when="coding-hint">coding-hint</span>	
							<span style="width:80px" ng-switch-default></span>
							<br><br>
						</div>
                        		</td>
                        		<td colspan="2">
                                		<div ng-repeat="kind3 in kind2">
                                        		<span ng-bind-html=" trustAsHtml(kind3.label) "></span>
                                        		<span ng-if="kind3.ref !== ''"> ({{kind3.ref}}) </span>
							<br><br>
						</div>
						<br>
					</td>
				</tr>
			</tbody>
		</table>
	</div>

	<div ng-if="eVm.pcode.classKind === 'category'">
	<div ng-repeat="siblings in eVm.siblings.siblings">
		<h5>
                                <span>{{siblings.code}} {{siblings.kinds[0].label}}</span>
                                <span ng-if="siblings.kinds[0].ref !== ''">({{siblings.kinds[0].ref}})</span>
                </h5>
		<br>
	<table border="1">
		<tbody>
			<tr style="font-size:10pt" ng-repeat="(kind1, kind2) in siblings.kinds | groupBy:'kind' ">
				<td style="width:80px;">			
					<div ng-switch on="kind1">
						<span ng-switch-when="preferred">Preferred</span>
						<span style="width:50px;font-weight:bold;font-style:italic" ng-switch-when="note">Note</span>
						<span style="width:50px;font-weight:bold;font-style:italic" ng-switch-when="inclusion">Incl.</span>
						<span style="width:50px;font-weight:bold;font-style:italic" ng-switch-when="exclusion">Excl.</span>
				 		<span style="width:50px;font-weight:bold;font-style:italic" ng-switch-when="introduction">Intro.</span>	
						<span ng-switch-when="coding-hint">coding-hint</span>	
						<span style="width:80px" ng-switch-default></span>
					</div>
					<br>
				</td>
				<td>
					<div ng-repeat="kind3 in kind2">
						<span ng-bind-html=" trustAsHtml(kind3.label) "></span>
                                		<span ng-if="kind3.ref !== ''"> ({{kind3.ref}}) </span>
					</div>
					<br>
				</td>
			</tr>
		</tbody>
	</table>
	<br><br>
	</div>
	</div>
	
<!--	
	<table class="table" ng-if="eVm.isLeafCode" >

        <table class="table" >
		<thead>
			<th>test1</th>
			<th>test2</th>
			<th>Ref</th>
		</thead>
		<tbody>
			
			<tr>
				<td> Code </td>
                                <td>{{ eVm.pcode.code }}</td>
				<td>{{ eVm.pcode.usageKind }}</td> 
                        </tr>
			
			<tr ng-repeat="siblings in eVm.siblings.siblings">
				<td>{{ siblings.kind }}</td>
				<td ng-bind-html="trustAsHtml(siblings.label)"></td>
				<td>{{ siblings.ref }}</td>
			</tr>

		</tbody>
	</table>
-->	
</div>
